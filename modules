#!/bin/false
# ## HUMAN-CODE - NO AI GENERATED CODE - AGENTS HANDSOFF

if [[ "$INC" != "" ]]; then
  ver_split=$(echo "$last_ver_num + $INC" | bc -l)
else
  ver_split=$(echo "$last_ver_num + .00" | bc -l)
fi
ver_maj=$(echo $ver_split | cut -d'.' -f1)
ver_min=$(echo $ver_split | cut -d'.' -f2)
if [[ "$ver_min" == *00* ]]; then
  ver_min=0
elif [[ "$ver_min" == *0* ]]; then
  ver_min=$(echo $ver_min | cut -d'0' -f2)
fi
ver_num=$ver_maj.$ver_min
if [[ "$INC" != "" ]]; then
  sed -i s/$(echo $last_ver_num)/$(echo $ver_num)/g docs/_layouts/default.html
  sed -i s/$(echo $last_ver_num)/$(echo $ver_num)/g docs/README.md
  sed -i s/$(echo $last_ver_num)/$(echo $ver_num)/g readme.md
  sed -i s/$(echo $last_ver_num)/$(echo $ver_num)/g Dockerfile
  sed -i s/last_ver_num=$last_ver_num/last_ver_num=$ver_split/g .pinned_ver
  echo -e "Version Incremented: From v$last_ver_num To v$ver_split\nTarget Branch: $ver_num.x\n"
else
  echo -e "Version: v$ver_split\nTarget Branch: $ver_num.x\n"
fi

$PUSHD_RES
  echo 'Starting cosign...' && pushd source >> /dev/null
  cosign_run_src="script -q -c 'cosign verify-attestation $source_loc \
    --certificate-oidc-issuer https://github.com/login/oauth \
    --certificate-identity $SIGSTORE_USR --type spdxjson \
    > source.sig.bundle' /dev/null > source.attested"
  quiet $cosign_run_src || quiet $cosign_run_src || return 78
  cat source.attested && echo && $POPD
$POPD

docker buildx create \
  --name $MODULE-builder $CROSS --buildkitd-flags "--oci-worker-rootless=true" \
  --driver docker-container --driver-opt "network=host,default-load=true" --bootstrap --use || return 78

if [[ "$last_rel_date" != "$rel_date" ]]; then
  sed -i s/last_epoch=$last_epoch/last_epoch=$source_date_epoch/g .pinned_ver
  sed -i s/last_rel_date=$last_rel_date/last_rel_date=$rel_date/g .pinned_ver
  docker buildx build $CROSS \
    --attest "type=provenance,mode=max,builder-id=local-build,reproducible=true" \
    --output "type=image,name=docker.io/$TRIPL,push=true,rewrite-timestamp=true" \
    --iidfile $RESULTS/$MODULE.image.id $PUSH --tag $TRIPL \
    --metadata-file $RESULTS/$MODULE.meta.json \
    --label $OCI.title=$TRIPL \
    --label $OCI.vendor=$REPO \
    --label $OCI.licenses=GPL-3.0 \
    --label $OCI.version=$rel_date \
    --label $OCI.base.name=$source_loc \
    --label $OCI.description=$no_ai \
    --build-arg SOURCE_DATE_EPOCH=$sde \
    --build-arg NODE_VERSION=$node_ver \
    --build-arg PNPM_VERSION=$pnpm_ver \
    --build-arg NVM_VERSION=$nvm_ver \
    --build-arg BRANCH=$ver_num \
    --build-arg SOURCE=$source \
    --build-arg COMMIT=$commit . || return 78
  docker buildx stop $MODULE-builder && wait
  docker buildx rm -f --all-inactive && wait
  docker buildx prune -f -a && wait && echo
  $PUSHD_RES
    attest_multi-arch $MODULE $TRIPL $CROSS || return 78
else
  $PUSHD_RES
fi
    for A in arm64 amd64; do
      scan_using_grype $MODULE $TRIPL $A || return 78
    done && unset A
  $POPD

docker run -it --cpus=$(nproc) \
  --network=host,\"driver-opt=network=host\" \
  --platform linux/$ANAME --cgroupns private \
  --name $MODULE -e SOURCE_DATE_EPOCH=$SDE \
  $(cat $RESULTS/$ANAME/$MODULE.manifest.ref) \
  $TEST $SIGNING_KEY || return 78

rm -r -f {builds/,}release && mkdir -p release || return 78
docker cp $MODULE:/$NAME/release/ . && \
mv release/release.sha*sum $RESULTS/ || return 78

$PUSHD_RES
  if [[ "$check_file" == "1" ]]; then
    cp /tmp/release.last.sha512sum release.last.sha512sum && \
    sha512sum -c release.last.sha512sum && REP="ly Reproduced" || return 78
  fi
  rm -f {/tmp/,}release.last.sha512sum && echo "Successful$REP Build!"
  echo "# Base Build System: $(uname -o) $(uname -r) $(uname -m) $(lsb_release -ds) $(lsb_release -cs) $(uname -v)" >> release.sha512sum && \
  awk '{a[i++]=$0}END{for(j=0;j<i-2;j++)print a[j];print a[i-1];print a[i-2]}' $RESULTS/release.sha512sum > tmp && mv tmp release.sha512sum || return 78
$POPD && ls -la release/ $RESULTS/ $RESULTS/* && return 0
