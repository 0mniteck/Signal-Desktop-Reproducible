BASH=/bin/bash
BASHOPTS=checkwinsize:cmdhist:complete_fullquote:extquote:force_fignore:globasciiranges:globskipdots:hostcomplete:interactive_comments:patsub_replacement:progcomp:promptvars:sourcepath
BASH_ALIASES=()
BASH_ARGC=()
BASH_ARGV=()
BASH_CMDS=()
BASH_LINENO=([0]="0")
BASH_LOADABLES_PATH=/usr/local/lib/bash:/usr/lib/bash:/opt/local/lib/bash:/usr/pkg/lib/bash:/opt/pkg/lib/bash:.
BASH_SOURCE=([0]="/home/shant/Signal-Desktop-Reproducible/./buildscript.sh")
BASH_VERSINFO=([0]="5" [1]="2" [2]="37" [3]="1" [4]="release" [5]="aarch64-unknown-linux-gnu")
BASH_VERSION='5.2.37(1)-release'
BRANCH=8.2.x
BUS=001
COLUMNS=169
CROSS='"--platform linux/arm64,linux/amd64"'
DEVICE=002
DIRSTACK=()
EPOCH=today
EUID=0
GROUPS=()
HOME=/home/shant
HOSTNAME=rock1
HOSTTYPE=aarch64
IFS=$' \t\n'
INC=.34
LINES=45
MACHTYPE=aarch64-unknown-linux-gnu
MOUNT=mmcblk1p1
OLDPWD=/home/shant/Signal-Desktop-Reproducible
OPTERR=1
OPTIND=5
OSTYPE=linux-gnu
PATH=/bin:/sbin:/snap/bin:/home/shant/docker/bin
PIPESTATUS=([0]="0")
PPID=1873
PS4='+ '
PUSH='"--push"'
PWD=/home/shant/.local/share/docker
RUN_DIR=/run/user/1000
SHELL=/bin/bash
SHELLOPTS=braceexpand:hashall:interactive-comments
SHLVL=1
TERM=xterm-256color
TEST=no
UID=0
_=
amd64_ver=3377
arm64_ver=3380
d=support
data_dir=/home/shant/.local/share
docker=/snap/docker/3380/bin/docker
docker_data=/home/shant/.local/share/docker
docker_path=/snap/docker/3380/bin
docker_plugins=/usr/libexec/docker/cli-plugins/docker-
docker_snap_ver=3380
dockerd=/snap/docker/3380/bin/dockerd
echt='setfacl -m u:shant:rw /dev/bus/usb/001/002'
home=/home/shant
local_bin=/home/shant/docker/bin
local_data=/home/shant/.local
local_lib=/home/shant/docker/lib
module=signal-desktop
nulled=/dev/null
opt='?'
path=/bin:/sbin:/snap/bin:/home/shant/docker/bin
plugins_path=usr/libexec/docker/cli-plugins
rel_date=03-16-2026
repo=0mniteck
rootless_path=/home/shant/.local/share/rootless
run_as=shant
run_dir=/run/user/1000
run_home=/home/shant
run_id=1000
save_id=0:0.env
sc_rules=/lib/udev/rules.d/60-scdaemon.rules
sed_ech=$'\\\\[Service\\\\]\\\nGroup=shant\\\nSlice=docker.slice\\'
set_facl='setfacl -m u:shant:rw /dev/bus/usb/001/002'
snap_path=snap/docker/3380
systemd_path=/etc/systemd/system
systemd_service=/etc/systemd/system/snap.docker.dockerd.service
sysusr_path=/home/shant/.local/share/systemd/user
sysusr_service=/home/shant/.local/share/systemd/user/docker.dockerd.service
term=xterm-256color
uname=aarch64
clean_all () 
{ 
    rm -r -f $home/$snap_path/*;
    rm -r -f $home/snap/docker/;
    rm -r -f $home/docker/;
    rm -r -f $home/.docker/;
    rm -r -f $data_dir/rootless*;
    rm -r -f $data_dir/systemd/;
    clean_most;
    rm -r -f /var/snap/docker/;
    rm -r -f /usr/libexec/docker/;
    rm -r -f /var/lib/snapd/cache/*
}
clean_most () 
{ 
    rm -r -f /home/root/*;
    rm -r -f /root/snap/docker/;
    rm -r -f $docker_data*;
    rm -r -f $run_dir/containerd/;
    rm -r -f $run_dir/docker*;
    rm -r -f $run_dir/runc/;
    rm -r -f /run/containerd/;
    rm -r -f /run/docker*;
    rm -r -f /run/runc/;
    rm -r -f /run/snap.docker/
}
quiet () 
{ 
    echt="$@";
    script -a -q -c "$echt" $nulled >> $nulled
}
systemd_ctl_common () 
{ 
    snap stop docker && wait;
    systemctl daemon-reload && wait;
    systemctl reset-failed && wait;
    systemctl stop snap.docker.* --all && wait
}
unmount () 
{ 
    quiet snap disable docker && sleep 1;
    quiet kill $(lsof -F p $docker_data 2>> $nulled | cut -d'p' -f2) && rm -r -f $docker_data/* && sync;
    quiet umount $docker_data && sleep 1;
    quiet systemd-cryptsetup detach $module && sleep 1;
    quiet dmsetup remove /dev/mapper/$module && sleep 1;
    rm -r -f $docker_data/ && sync
}
HOME=/home/shant
OLDPWD=/home/shant/Signal-Desktop-Reproducible
PATH=/bin:/sbin:/snap/bin:/home/shant/docker/bin
PWD=/home/shant/.local/share/docker
SHLVL=1
TERM=xterm-256color
_=/bin/env
